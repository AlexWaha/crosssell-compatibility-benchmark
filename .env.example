# AVTC environment variables - copy to .env and fill in real values.
# This file is committed. .env is gitignored.
# All three services read from the single root .env (injected via compose env_file).
#
# Group ownership (which service uses which variables):
#   Catalog DB:        engine, api, worker
#   Metrics DB:        engine, api
#   OpenAI / LLM:     engine only
#   Typesense:         engine, api
#   Redis:             worker only
#   Engine URL:        api, worker
#   Compatibility:     engine only

# ---------------------------------------------------------------------------
# Catalog DB (avtc_catalog) - engine, api, worker
# ---------------------------------------------------------------------------
DB_HOST=db
DB_USER=user
DB_PASSWORD=secret
MYSQL_PORT=3306
DB_CATALOG_DATABASE=avtc_catalog

# ---------------------------------------------------------------------------
# Metrics DB (avtc_metrics) - engine, api
# ---------------------------------------------------------------------------
DB_METRICS_DATABASE=avtc_metrics

# ---------------------------------------------------------------------------
# OpenAI / LLM - engine only
# ---------------------------------------------------------------------------
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_KEY=sk-...
PRIMARY_MODEL=gpt-5-nano
JUDGE_MODEL=gpt-5-mini
EMBED_MODEL=text-embedding-3-small
EMBED_BASE_URL=https://api.openai.com/v1
EMBED_PROVIDER=openai
EMBED_DIMS=1024
MAX_TOKENS=8000
REASONING_EFFORT=minimal
# "real" hits the provider; "mock" routes to MockLLM ($0 smoke tests)
LLM_MODE=mock
# Mock scenario: valid | slow | error | truncated
MOCK_SCENARIO=valid

# ---------------------------------------------------------------------------
# Typesense - engine, api
# ---------------------------------------------------------------------------
TYPESENSE_HOST=typesense
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=xyz
TYPESENSE_COLLECTION=products_v2

# ---------------------------------------------------------------------------
# Redis - worker only (arq queue broker)
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ---------------------------------------------------------------------------
# Engine URL - api, worker (HTTP delegation)
# ---------------------------------------------------------------------------
ENGINE_URL=http://engine:9000

# ---------------------------------------------------------------------------
# Compatibility pipeline parameters - engine only
# ---------------------------------------------------------------------------
COMPAT_BATCH_SIZE=10
COMPAT_TOP_K=60
COMPAT_ALPHA=0.6
COMPAT_TAU_S=0.15
COMPAT_TAU_L=0.5
# 'oneshot' = LLM holistic verify (viable on attribute-poor catalogs);
# 'jit' = rule-based logical layer (needs structured compatibility attributes)
COMPAT_MODE=oneshot
EXPERIMENT_ID=cat_priors_v1
RETRIEVAL_STRATEGY=cat_priors
# Optional: OpenAI RPM limiter (0 = disabled, no behavior change)
OPENAI_RPM_LIMIT=0
